DISCORD_TOKEN=your_discord_token_here
OPTIMISM_RPC_URL=https://mainnet.optimism.io
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
BOT_PRIVATE_KEY=
BOT_API_SECRET=
HTTP_PORT=8080
# Optional: comma-separated voice channel IDs the awareness layer tracks.
# Empty = track every voice channel the bot can see.
FRACTAL_VOICE_CHANNEL_IDS=
# Farcaster integration (reads). Neynar API key for member Farcaster awareness -
# same provider ZOL uses. Reads only; no bot FID needed for resolveFarcaster.
NEYNAR_API_KEY=
# Farcaster identity the bot posts as. Reuses @zolbot (FID 3338501); a dedicated
# fractal-bot FID can replace this later. Used by the write path (future PR).
FARCASTER_BOT_FID=3338501
